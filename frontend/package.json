{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run generate-blog-content && vite",
    "build": "npm run generate-blog-content && tsc -p tsconfig.build.json && vite build && tsx scripts/build-blog-static.ts",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "preview": "vite preview",
