    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "dotenv": "^17.2.2",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.2",
