    "@tanstack/react-router": "^1.168.24",
    "axios": "^1.15.2",
    "form-data": "^4.0.5",
    "gray-matter": "^4.0.3",
    "html-react-parser": "^6.0.0",
    "marked": "^17.0.6",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "7.62.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
