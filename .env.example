IG_SCRAPE_WORKER_DATABASE_URL=
#secret
IG_SCRAPE_WORKER_REDIS_URL=
IG_SCRAPE_WORKER_BACKEND_BASE_URL=http://127.0.0.1:8000
#secret
IG_SCRAPE_WORKER_SECRET_KEY_IG_CREDENTIALS=
#secret
IG_SCRAPE_WORKER_OPENAI_API_KEY=
IG_SCRAPE_WORKER_SYSTEM_ADMIN_EMAIL=
#secret
IG_SCRAPE_WORKER_SYSTEM_ADMIN_PASSWORD=
IG_SCRAPE_WORKER_ID=
IG_SCRAPE_WORKER_POLL_SECONDS=1
IG_SCRAPE_WORKER_HEARTBEAT_SECONDS=20
IG_SCRAPE_WORKER_LEASE_SECONDS=900
IG_SCRAPE_WORKER_JOB_CONTROL_TERMINAL_STATE_TTL_SECONDS=86400
IG_SCRAPE_WORKER_JOB_CONTROL_QUEUE_MAXLEN=10000
IG_SCRAPE_WORKER_MAX_ATTEMPTS=3
IG_SCRAPE_WORKER_ERROR_MAX_LEN=4000

# Instagram scraper runtime
IG_SCRAPER_MAX_CONCURRENT=2
