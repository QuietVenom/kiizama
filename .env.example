# Used by backend to generate links in emails to the authenticated app
# For local development, use the direct frontend port.
FRONTEND_HOST=http://localhost:5173

# Used by the frontend Docker build and local frontend env files.
VITE_API_URL=http://localhost:8000
VITE_SITE_URL=https://kiizama.com

# local | staging | production
ENVIRONMENT=local

PROJECT_NAME="Kiizama"

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:5173,https://localhost,https://localhost:5173,https://127.0.0.1,https://127.0.0.1:5173"
# SECRET
SECRET_KEY=changethis
# SECRET
SECRET_KEY_IG_CREDENTIALS=changethis
FIRST_SUPERUSER=admin@example.com
# SECRET
FIRST_SUPERUSER_PASSWORD=ChangeThis1!
SYSTEM_ACCESS_TOKEN_EXPIRE_MINUTES=60
SYSTEM_ADMIN_EMAIL=
# SECRET
SYSTEM_ADMIN_PASSWORD=

# Emails
# SECRET
RESEND_API_KEY=
EMAILS_FROM_EMAIL=noreply@mail.kiizama.com
EMAILS_FROM_NAME=

# Postgres preferred URLs (recommended)
# SECRET
DATABASE_URL=
# SECRET
DATABASE_URL_PRODUCTION_INTERNAL=

# Postgres split values (legacy fallback)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
# SECRET
POSTGRES_PASSWORD=changethis

# Local isolated test DB
# SECRET
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:55432/app_test
POSTGRES_TEST_DB=app_test
POSTGRES_TEST_USER=postgres
# SECRET
POSTGRES_TEST_PASSWORD=postgres
POSTGRES_TEST_PORT=55432

SENTRY_DSN=

# SECRET
REDIS_URL=
# SECRET
FLY_REDIS_URL=
RATE_LIMIT_ENABLED=true
JOB_CONTROL_TERMINAL_STATE_TTL_SECONDS=86400
USER_EVENTS_STREAM_MAXLEN=100
USER_EVENTS_SSE_READ_BLOCK_MS=10000
JOB_CONTROL_QUEUE_MAXLEN=10000

# Legacy worker job flow toggle in backend
IG_SCRAPER_WORKER_JOBS_ENABLED=true
# Backend-managed Apify job flow toggle
IG_SCRAPER_APIFY_JOBS_ENABLED=true
IG_SCRAPER_APIFY_WORKER_ID=backend-apify
IG_SCRAPER_APIFY_LEASE_SECONDS=90
IG_SCRAPER_APIFY_HEARTBEAT_SECONDS=30
IG_SCRAPER_APIFY_POLL_SECONDS=2
IG_SCRAPER_APIFY_MAX_ATTEMPTS=3
IG_SCRAPER_APIFY_MAX_CONCURRENT_JOBS=4

# Docker images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# OpenAI
# SECRET
OPENAI_API_KEY=
REPUTATION_OPENAI_TIMEOUT_SECONDS=180
REPUTATION_OPENAI_MAX_RETRIES=2

# Stripe billing
# SECRET
STRIPE_SECRET_KEY=
# SECRET
STRIPE_WEBHOOK_SECRET=
STRIPE_BASE_PRICE_ID=
BILLING_TRIAL_DAYS=7
STRIPE_CUSTOMER_SYNC_POLL_SECONDS=60
STRIPE_CUSTOMER_SYNC_STALE_PROCESSING_SECONDS=300

# Apify
